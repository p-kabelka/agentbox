#!/usr/bin/env python3
"""agentbox — isolated agent workspace manager"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import NoReturn

import yaml

AGENTBOX_HOME   = Path(os.environ.get("AGENTBOX_HOME", Path.home() / ".local" / "share" / "agentbox"))
AGENTBOX_PRESET = os.environ.get("AGENTBOX_PRESET", "default")

HARNESS_CONTAINERFILES = {
    p.name.split(".", 1)[1]: p.name
    for p in sorted((AGENTBOX_HOME / "agent").glob("Containerfile.*"))
}


# ── Helpers ───────────────────────────────────────────────────────────────────

def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def project_name(path: Path) -> str:
    name = re.sub(r"[^a-z0-9]+", "-", path.resolve().name.lower()).strip("-")
    return name or "agentbox"


def free_port() -> int:
    with socket.socket() as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def find_agentbox_dir() -> Path | None:
    d = Path.cwd()
    while d != d.parent:
        if (d / ".agentbox" / "sessions").is_dir():
            return d
        d = d.parent
    return None


def require_agentbox() -> Path:
    p = find_agentbox_dir()
    if p is None:
        die("no .agentbox/ found in this directory or any parent.\n"
            "       Run 'agentbox run --name <name>' to create one.")
    return p  # type: ignore[return-value]


def get_sessions(project_dir: Path) -> list[str]:
    sessions_dir = project_dir / ".agentbox" / "sessions"
    return sorted(d.name for d in sessions_dir.iterdir() if d.is_dir()) if sessions_dir.is_dir() else []


def require_session(project_dir: Path, name: str | None) -> Path:
    """Return session_dir, auto-detecting if exactly one session exists."""
    sessions_dir = project_dir / ".agentbox" / "sessions"
    if name:
        d = sessions_dir / name
        if not d.is_dir():
            die(f"session '{name}' not found — run: agentbox list")
        return d
    sessions = get_sessions(project_dir)
    if len(sessions) == 1:
        return sessions_dir / sessions[0]
    elif not sessions:
        die("No sessions. Run: agentbox init --name <name>")
    else:
        die(f"Multiple sessions ({', '.join(sessions)}) — specify: --name <name>")
    raise AssertionError  # unreachable


def compose(session_dir: Path, *args: str, **kwargs) -> subprocess.CompletedProcess:
    name = session_dir.name
    project_dir = session_dir.parent.parent.parent
    env = {
        **os.environ,
        "AGENTBOX_HOME": str(AGENTBOX_HOME),
    }
    cmd = [
        "podman", "compose",
        "--project-name", f"agentbox-{project_name(project_dir)}-{name}",
        "-f", str((session_dir / "compose.yaml").resolve()),
        *args,
    ]
    return subprocess.run(cmd, env=env, **kwargs)


def wait_healthy(session_dir: Path) -> None:
    web_port = read_port(session_dir)
    print("==> Waiting for proxy", end="", flush=True)
    for _ in range(40):
        r = subprocess.run(["curl", "-so", "/dev/null", f"http://localhost:{web_port}/"], capture_output=True)
        if r.returncode == 0:
            print(" ready.")
            return
        print(".", end="", flush=True)
        time.sleep(2)
    print(" timed out!")
    compose(session_dir, "logs", "--tail=40", "proxy")
    sys.exit(1)


def read_port(session_dir: Path) -> int | None:
    compose_cfg = load_yaml(session_dir / "compose.yaml") if (session_dir / "compose.yaml").is_file() else {}
    ports = compose_cfg.get("services", {}).get("proxy", {}).get("ports", [])
    if ports:
        # "127.0.0.1:<port>:8081"
        return int(str(ports[0]).split(":")[1])
    return None


def load_yaml(path: Path) -> dict:
    with path.open() as f:
        return yaml.safe_load(f) or {}


def save_yaml(path: Path, cfg: dict) -> None:
    with path.open("w") as f:
        yaml.dump(cfg, f, default_flow_style=False, allow_unicode=True)


def resolve_preset(name: str) -> Path:
    custom = AGENTBOX_HOME / "custom" / "presets" / name
    if custom.is_dir():
        return custom
    return AGENTBOX_HOME / "presets" / name


def resolve_preset_file(preset_dir: Path, filename: str) -> Path | None:
    path = preset_dir / filename
    if path.is_file():
        return path
    default = AGENTBOX_HOME / "presets" / "default" / filename
    if default.is_file():
        return default
    return None


def generate_compose(
    session_dir: Path,
    project_dir: Path,
    name: str,
    port: int,
    proxy_cfg: dict,
    agent_cfg: dict,
    context_mounts: list[tuple[str, str, bool]],
) -> None:
    """Build a unified compose.yaml from compose-base.yaml and preset config."""
    base = load_yaml(AGENTBOX_HOME / "compose-base.yaml")

    # --- Proxy service ---
    proxy = base["services"]["proxy"]
    proxy["ports"] = [f"127.0.0.1:{port}:8081"]

    proxy_volumes: list = proxy.get("volumes", [])
    proxy_volumes.append("./proxy.yaml:/config/proxy.yaml:ro,Z")

    vertex_enabled = any(
        p.get("name") == "vertex" and p.get("enabled")
        for p in proxy_cfg.get("providers", [])
    )
    if vertex_enabled:
        gcloud = Path.home() / ".config" / "gcloud"
        if gcloud.is_dir():
            proxy_volumes.append(f"{gcloud}:/root/.config/gcloud:ro,Z")

    for cert_name in proxy_cfg.get("trusted_certificates", []):
        cert_path = AGENTBOX_HOME / "custom" / "certs" / cert_name
        if cert_path.is_file():
            proxy_volumes.append(f"{cert_path}:/custom-certs/{cert_name}:ro,Z")
        else:
            print(f"Warning: trusted certificate not found: {cert_path}")

    for p in proxy_cfg.get("providers", []):
        if not p.get("enabled"):
            continue
        key_file = p.get("api_key_file", "")
        if key_file:
            host_path = Path(key_file).expanduser().resolve()
            if host_path.is_file():
                proxy_volumes.append(f"{host_path}:/run/secrets/{host_path.name}:ro,Z")
            else:
                print(f"Provider {p.get('name', '?')}: api_key_file not found: {host_path}")

    proxy["volumes"] = proxy_volumes

    proxy_env: dict = proxy.get("environment", {})
    proxy_env.update(proxy_cfg.get("environment") or {})
    proxy_env["AGENTBOX_NAME"] = name
    proxy["environment"] = proxy_env

    # --- Agent service ---
    agent = base["services"]["agent"]
    agent["runtime"] = "krun"

    agent_volumes: list = agent.get("volumes", [])
    if (session_dir / "dotfiles").is_dir():
        agent_volumes.append("./dotfiles:/agentbox-dotfiles:ro,Z")
    has_bundle = (session_dir / "source.bundle").is_file()
    output_dir = session_dir / "output.git"
    if has_bundle:
        agent_volumes.append("./source.bundle:/source/project.bundle:ro,Z")
    if output_dir.is_dir():
        agent_volumes.append("./output.git:/output/repo.git:Z")
        # Read-only bind mount over hooks and git config — kernel-enforced, not just chmod.
        # Without this the agent can chmod 755 the dir and write executable
        # hooks or custom scripts in git config.
        agent_volumes.append("./output.git/hooks:/output/repo.git/hooks:ro")
        agent_volumes.append("./output.git/config:/output/repo.git/config:ro")
    if not has_bundle and not output_dir.is_dir():
        agent_volumes.append(f"{project_dir}:/workspace:Z")
    for src, dst, writable in context_mounts:
        opts = "Z" if writable else "ro,Z"
        agent_volumes.append(f"{src}:/context/{dst}:{opts}")
    agent["volumes"] = agent_volumes

    agent_image = agent_cfg.get("agent_image", "localhost/agentbox-agent-base:latest")
    agent["image"] = agent_image

    agent_preset_env = agent_cfg.get("environment") or {}
    agent_env: dict = agent.get("environment", {})
    agent_env.update(agent_preset_env)
    agent_env["AGENTBOX_NAME"] = name
    agent["environment"] = agent_env

    save_yaml(session_dir / "compose.yaml", base)


# ── Commands ──────────────────────────────────────────────────────────────────

def _build_images(no_cache: bool = False, harnesses: list[str] | None = None) -> None:
    extra = ["--no-cache"] if no_cache else []
    agent_ctx = AGENTBOX_HOME / "agent"

    (AGENTBOX_HOME / "secrets").mkdir(parents=True, exist_ok=True)

    for tag, ctx, containerfile in [
        ("localhost/agentbox-proxy:latest", AGENTBOX_HOME / "proxy", "Containerfile"),
        ("localhost/agentbox-agent-base:latest", agent_ctx, "Containerfile.base"),
    ]:
        subprocess.run(
            ["podman", "build", *extra, "-f", str(ctx / containerfile), "-t", tag, str(ctx)],
            check=True,
        )

    targets = harnesses if harnesses else list(HARNESS_CONTAINERFILES.keys())
    for name in targets:
        containerfile = HARNESS_CONTAINERFILES[name]
        cf_path = agent_ctx / containerfile
        if not cf_path.is_file():
            print(f"Warning: {cf_path} not found, skipping {name} image build")
            continue
        if name == "claude" and not (agent_ctx / "keys" / "claude-code.asc").is_file():
            die(f"Claude Code GPG key not found at {agent_ctx / 'keys' / 'claude-code.asc'}\n"
                f"       Download it and verify its fingerprint:\n"
                f"         curl -fsSLo {agent_ctx / 'keys' / 'claude-code.asc'} https://downloads.claude.ai/keys/claude-code.asc\n"
                f"         gpg --show-keys --fingerprint {agent_ctx / 'keys' / 'claude-code.asc'}")
        tag = f"localhost/agentbox-agent-{name}:latest"
        print(f"==> Building {name} agent image...")
        subprocess.run(
            ["podman", "build", *extra, "-f", str(cf_path), "-t", tag, str(agent_ctx)],
            check=True,
        )


def _validate_harnesses(names: list[str]) -> None:
    for name in names:
        if name not in HARNESS_CONTAINERFILES:
            die(f"unknown harness '{name}'. Choices: {', '.join(HARNESS_CONTAINERFILES)}")


def cmd_build(args) -> None:
    if args.harnesses:
        _validate_harnesses(args.harnesses)
    print("==> Building images...")
    _build_images(harnesses=args.harnesses or None)
    print("==> Done. Run 'agentbox update' after pulling a new version.")


def cmd_update(args) -> None:
    if args.harnesses:
        _validate_harnesses(args.harnesses)
    print("==> Rebuilding images without cache...")
    _build_images(no_cache=True, harnesses=args.harnesses or None)
    print("==> Done.")


def _launch(session_dir: Path, cmd: list[str] | None = None) -> None:
    name = session_dir.name
    project_dir = session_dir.parent.parent.parent
    compose(session_dir, "up", "-d", "proxy", check=True)
    web_port = read_port(session_dir)
    if web_port:
        print(f"  Traffic monitor: http://localhost:{web_port} | agentbox logs | git fetch agentbox-{name}")
    result = compose(session_dir, "run", "--rm", "agent", *(cmd or []))
    # Auto-fetch when the session ends
    output_git = session_dir / "output.git"
    if output_git.is_dir():
        print(f"\n==> Fetching agent output (agentbox-{name})...")
        r = subprocess.run(
            ["git", "-C", str(project_dir), "-c", "core.hooksPath=/dev/null",
             "fetch", f"agentbox-{name}"],
        )
        if r.returncode == 0:
            ls = subprocess.run(
                ["git", "-C", str(project_dir), "branch", "-r", "--list", f"agentbox-{name}/*"],
                capture_output=True, text=True,
            )
            branches = [b.strip() for b in ls.stdout.splitlines() if b.strip()]
            for b in branches:
                print(f"  {b}")
            if branches:
                print(f"  To apply: git merge {branches[0]}")
    sys.exit(result.returncode)


def cmd_init(args) -> None:
    project_dir = Path(args.dir).resolve() if args.dir else Path.cwd()
    agentbox_dir = project_dir / ".agentbox"
    name = args.name or time.strftime("%Y%m%d-%H%M%S")
    if not re.match(r"^[a-z0-9][a-z0-9._-]*$", name):
        die(f"invalid session name '{name}' — use lowercase letters, digits, hyphens, dots")
    session_dir = agentbox_dir / "sessions" / name

    print(f"==> Initializing agentbox '{name}': {project_dir}")
    agentbox_dir.mkdir(parents=True, exist_ok=True)
    session_dir.mkdir(parents=True, exist_ok=True)

    proxy_file = session_dir / "proxy.yaml"
    preset_dir = resolve_preset(args.preset)
    if not preset_dir.is_dir():
        die(f"preset '{args.preset}' not found")
    proxy_src = resolve_preset_file(preset_dir, "proxy.yaml")
    if not proxy_src:
        die(f"preset '{args.preset}' has no proxy.yaml (and no default fallback)")
    if not proxy_file.is_file():
        # Copy proxy config without the environment field (environment goes into compose.yaml)
        proxy_cfg = load_yaml(proxy_src)
        proxy_cfg.pop("environment", None)
        save_yaml(proxy_file, proxy_cfg)
        print(f"    Copied preset '{args.preset}' — edit .agentbox/sessions/{name}/proxy.yaml to enable providers.")

    proxy_cfg = load_yaml(proxy_src)
    agent_src = resolve_preset_file(preset_dir, "agent.yaml")
    agent_cfg = load_yaml(agent_src) if agent_src else {}

    # Write dotfiles from agent config into session dotfiles directory
    dotfiles = agent_cfg.get("dotfiles", {})
    if dotfiles:
        dotfiles_dir = session_dir / "dotfiles"
        for rel_path, content in dotfiles.items():
            clean = rel_path.lstrip("~").lstrip("/")
            dest = dotfiles_dir / clean
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_text(content or "")

    use_git = not args.no_git
    if use_git:
        in_repo = subprocess.run(
            ["git", "-C", str(project_dir), "rev-parse", "--git-dir"],
            capture_output=True,
        ).returncode == 0

        if in_repo:
            branch = args.branch
            if not branch:
                branch = subprocess.run(
                    ["git", "-C", str(project_dir), "branch", "--show-current"],
                    capture_output=True, text=True,
                ).stdout.strip()
            if not branch:  # detached HEAD
                branch = subprocess.run(
                    ["git", "-C", str(project_dir), "rev-parse", "--short", "HEAD"],
                    capture_output=True, text=True, check=True,
                ).stdout.strip()
                print(f"    Detached HEAD — snapshotting commit {branch}")

            print(f"==> Creating source bundle (branch: {branch})...")
            subprocess.run(
                ["git", "-C", str(project_dir), "bundle", "create",
                 str(session_dir / "source.bundle"), "HEAD", branch],
                check=True,
            )

            output_git = session_dir / "output.git"
            subprocess.run(["git", "init", "--bare", str(output_git), "--quiet"], check=True)
            (output_git / "hooks").mkdir(exist_ok=True)
            (output_git / "config").touch(exist_ok=True)

            remote = f"agentbox-{name}"
            has_remote = subprocess.run(
                ["git", "-C", str(project_dir), "remote", "get-url", remote],
                capture_output=True,
            ).returncode == 0
            if has_remote:
                subprocess.run(["git", "-C", str(project_dir), "remote", "set-url", remote, str(output_git.resolve())], check=True)
            else:
                subprocess.run(["git", "-C", str(project_dir), "remote", "add", remote, str(output_git.resolve())], check=True)
            print(f"    Git remote '{remote}' registered — 'git fetch {remote}' to review output mid-session.")
        else:
            print("    No git repo found; falling back to --no-git mode.")
            use_git = False

    # Preserve existing context mounts from compose.yaml, then add any new ones from args
    context_mounts: list[tuple[str, str, bool]] = _read_context_mounts(session_dir)
    seen_dsts: set[str] = {d for _, d, _ in context_mounts}
    for spec in args.ro_mounts:
        src_str, _, dst = spec.partition(":")
        src = str(Path(src_str).resolve())
        dst = dst or Path(src_str).name
        if not Path(src).exists():
            die(f"mount source does not exist: {src}")
        if dst not in seen_dsts:
            context_mounts.append((src, dst, False))
            seen_dsts.add(dst)
    for spec in args.rw_mounts:
        src_str, _, dst = spec.partition(":")
        src = str(Path(src_str).resolve())
        dst = dst or Path(src_str).name
        if not Path(src).exists():
            die(f"mount source does not exist: {src}")
        if dst not in seen_dsts:
            context_mounts.append((src, dst, True))
            seen_dsts.add(dst)

    # Read existing port from compose.yaml if re-initializing, otherwise pick a free port
    web_port = read_port(session_dir) or free_port()

    generate_compose(
        session_dir=session_dir,
        project_dir=project_dir,
        name=name,
        port=web_port,
        proxy_cfg=proxy_cfg,
        agent_cfg=agent_cfg,
        context_mounts=context_mounts,
    )

    if args.start:
        _launch(session_dir)
    else:
        print(f"  Initialized. Run 'agentbox start --name {name}' to start")
        print(f"  or start a tmux session: agentbox start --name {name} -- tmux -u new-session -s agent 'bash -l' ';' send-keys -t agent 'agent' Enter")


def cmd_start(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    cmd = [a for a in (args.exec_cmd or [])] or None
    _launch(session_dir, cmd)


def cmd_stop(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    compose(session_dir, "down", check=True)


def cmd_logs(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    result = compose(session_dir, "logs", "--follow", "--tail=100", "proxy")
    sys.exit(result.returncode)


def cmd_web(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    web_port = read_port(session_dir)
    if not web_port:
        die("proxy port not found in session compose.yaml")
    print(f"http://localhost:{web_port}")


def _update_allowlist(host: str, add: bool, name: str | None) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, name)
    config_path = session_dir / "proxy.yaml"
    cfg = load_yaml(config_path)
    hosts: list[str] = cfg.setdefault("extra_allowed_hosts", [])
    session_name = session_dir.name
    if add:
        if host not in hosts:
            hosts.append(host)
            save_yaml(config_path, cfg)
            print(f"Added '{host}' to allowlist for session '{session_name}'.")
        else:
            print(f"'{host}' already in allowlist for session '{session_name}'.")
    else:
        if host in hosts:
            hosts.remove(host)
            cfg["extra_allowed_hosts"] = hosts
            save_yaml(config_path, cfg)
            print(f"Removed '{host}' from allowlist for session '{session_name}'.")
        else:
            print(f"'{host}' not in allowlist for session '{session_name}'.")
    compose(session_dir, "exec", "-T", "proxy", "curl", "-sf", "http://localhost:8082/reload", check=True)


def cmd_allow(args) -> None:
    _update_allowlist(args.host, add=True, name=args.name)


def cmd_deny(args) -> None:
    _update_allowlist(args.host, add=False, name=args.name)


def cmd_proxy_reload(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    compose(session_dir, "exec", "-T", "proxy", "curl", "-sf", "http://localhost:8082/reload", check=True)
    print("Proxy config reloaded.")


def cmd_proxy_restart(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    compose(session_dir, "restart", "proxy", check=True)
    wait_healthy(session_dir)


def cmd_remove(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    name = session_dir.name

    compose(session_dir, "down", "-v", check=True)

    remote = f"agentbox-{name}"
    subprocess.run(["git", "-C", str(project_dir), "remote", "remove", remote],
                   capture_output=True)  # best-effort; may not be a git repo

    shutil.rmtree(session_dir, ignore_errors=True)

    print(f"Removed session '{name}'.")


def cmd_remote_cleanup(args) -> None:
    project_dir = find_agentbox_dir()
    if project_dir is None:
        project_dir = Path.cwd()

    if subprocess.run(
        ["git", "-C", str(project_dir), "rev-parse", "--git-dir"],
        capture_output=True,
    ).returncode != 0:
        die("not a git repository")

    result = subprocess.run(
        ["git", "-C", str(project_dir), "remote"],
        capture_output=True, text=True, check=True,
    )
    agentbox_remotes = [r for r in result.stdout.splitlines() if r.startswith("agentbox-")]

    if not agentbox_remotes:
        print("No agentbox remotes found.")
        return

    sessions = get_sessions(project_dir)
    valid_remotes = {f"agentbox-{s}" for s in sessions}
    stale = [r for r in agentbox_remotes if r not in valid_remotes]

    if not stale:
        print("No stale agentbox remotes found.")
        return

    removed = 0
    for remote in stale:
        print(f"Removing stale remote '{remote}'...")
        if subprocess.run(
            ["git", "-C", str(project_dir), "remote", "remove", remote],
            capture_output=True,
        ).returncode == 0:
            removed += 1
        else:
            print(f"  Warning: failed to remove remote '{remote}'")

    print(f"Cleaned up {removed} stale remote(s).")


def _read_context_mounts(session_dir: Path) -> list[tuple[str, str, bool]]:
    compose_cfg = load_yaml(session_dir / "compose.yaml") if (session_dir / "compose.yaml").is_file() else {}
    volumes = compose_cfg.get("services", {}).get("agent", {}).get("volumes", [])
    mounts = []
    for vol in volumes:
        if isinstance(vol, str) and ":/context/" in vol:
            parts = vol.split(":")
            src, dst_path = parts[0], parts[1]
            dst = dst_path[len("/context/"):]
            writable = len(parts) < 3 or not parts[2].startswith("ro")
            mounts.append((src, dst, writable))
    return mounts


def cmd_mount(args) -> None:
    sub = args.subcmd or "list"
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)

    if sub == "list":
        mounts = _read_context_mounts(session_dir)
        if not mounts:
            print("No extra reference mounts. Add one: agentbox mount add /path/to/project[:name]")
        else:
            for src, dst, writable in mounts:
                mode = "[rw]" if writable else "[ro]"
                tag = "  [MISSING]" if not Path(src).exists() else ""
                print(f"  {src}  →  /context/{dst}  {mode}{tag}")

    elif sub == "add":
        src_str, _, dst = args.spec.partition(":")
        src = str(Path(src_str).resolve())
        dst = dst or Path(src_str).name
        if not Path(src).exists():
            die(f"source path does not exist: {src}")
        mounts = _read_context_mounts(session_dir)
        if any(d == dst for _, d, _ in mounts):
            die(f"/context/{dst} already mounted. Remove first: agentbox mount remove {dst}")
        compose_cfg = load_yaml(session_dir / "compose.yaml")
        opts = "Z" if args.writable else "ro,Z"
        compose_cfg["services"]["agent"]["volumes"].append(f"{src}:/context/{dst}:{opts}")
        save_yaml(session_dir / "compose.yaml", compose_cfg)
        mode = "[rw]" if args.writable else "[ro]"
        print(f"Added {src} → /context/{dst} {mode}. Start the session to apply.")

    elif sub == "remove":
        compose_cfg = load_yaml(session_dir / "compose.yaml")
        volumes = compose_cfg["services"]["agent"]["volumes"]
        new_volumes = [v for v in volumes if not (isinstance(v, str) and v.split(":")[1] == f"/context/{args.dst}")]
        if len(new_volumes) == len(volumes):
            die(f"no mount '{args.dst}' found. List: agentbox mount list")
        compose_cfg["services"]["agent"]["volumes"] = new_volumes
        save_yaml(session_dir / "compose.yaml", compose_cfg)
        print(f"Removed /context/{args.dst}. Start the session to apply.")


def cmd_list(args) -> None:
    project_dir = require_agentbox()
    sessions = get_sessions(project_dir)
    if not sessions:
        print("No sessions. Run: agentbox init --name <name>")
        return
    running = subprocess.run(
        ["podman", "ps", "--filter", "label=com.docker.compose.project", "--format", "{{.Names}}"],
        capture_output=True, text=True,
    ).stdout.lower()
    pname_prefix = f"agentbox-{project_name(project_dir)}"
    for s in sessions:
        port = read_port(project_dir / ".agentbox" / "sessions" / s)
        active = f"{pname_prefix}-{s}_" in running
        status = "running" if active else "stopped"
        port_info = f"  http://localhost:{port}" if port and active else ""
        print(f"  {s}  [{status}]{port_info}")


def cmd_status(args) -> None:
    result = subprocess.run(
        ["podman", "ps",
         "--filter", "label=com.docker.compose.project",
         "--format", "table {{.Names}}\t{{.Status}}\t{{.Ports}}"],
        capture_output=True, text=True,
    )
    lines = [ln for ln in result.stdout.splitlines() if "agentbox" in ln.lower()]
    print("\n".join(lines) if lines else "(no running containers)")


def cmd_preset(args) -> None:
    sub = args.subcmd or "list"

    if sub == "list":
        names = set()
        for d in [AGENTBOX_HOME / "custom" / "presets", AGENTBOX_HOME / "presets"]:
            if d.is_dir():
                names.update(p.name for p in d.iterdir() if p.is_dir())
        for n in sorted(names):
            print(n)

    elif sub == "edit":
        filename = f"{args.file}.yaml"
        preset_dir = resolve_preset(args.name)
        target = preset_dir / filename
        if not target.is_file():
            die(f"preset '{args.name}' {filename} not found at {target}")
        subprocess.run([os.environ.get("EDITOR", "vi"), str(target)], check=True)
        print(f"Preset saved ({filename}).")

    elif sub == "copy":
        src_dir = resolve_preset(args.src)
        if not src_dir.is_dir():
            die(f"source preset '{args.src}' not found")
        dst_dir = AGENTBOX_HOME / "custom" / "presets" / args.dst
        dst_dir.mkdir(parents=True, exist_ok=True)
        for filename in ["proxy.yaml", "agent.yaml"]:
            src_file = resolve_preset_file(src_dir, filename)
            if src_file:
                shutil.copy(src_file, dst_dir / filename)
        print(f"Created preset '{args.dst}' from '{args.src}'. Edit: agentbox preset edit <proxy|agent> {args.dst}")


def main() -> None:
    def subparser_with_name(p: argparse.ArgumentParser) -> argparse.ArgumentParser:
        p.add_argument("--name", "-n", metavar="NAME", help="Session name (auto-detected if only one session exists)")
        return p

    parser = argparse.ArgumentParser(prog="agentbox", description="Isolated agent workspace manager.")
    subcommand = parser.add_subparsers(dest="cmd")

    build_subcommand = subcommand.add_parser("build", help="Build proxy + agent images")
    build_subcommand.add_argument("harnesses", nargs="*", metavar="HARNESS", help=f"Harness images to build (default: all). Choices: {', '.join(HARNESS_CONTAINERFILES)}")
    update_subcommand = subcommand.add_parser("update", help="Rebuild images without cache")
    update_subcommand.add_argument("harnesses", nargs="*", metavar="HARNESS", help=f"Harness images to rebuild (default: all). Choices: {', '.join(HARNESS_CONTAINERFILES)}")
    subcommand.add_parser("list", help="List sessions for the current project")
    subcommand.add_parser("ls", help="Alias for list")
    subcommand.add_parser("status", help="List running agentbox containers")

    init_subcommand = subcommand.add_parser("init", help="Initialize a new agentbox session (use --start to also launch)")
    init_subcommand.add_argument("dir", nargs="?")
    init_subcommand.add_argument("--name", "-n", metavar="NAME", help="Session name (default: timestamp)")
    init_subcommand.add_argument("--preset", default=AGENTBOX_PRESET)
    init_subcommand.add_argument("--branch", default="")
    init_subcommand.add_argument("--no-git", action="store_true")
    init_subcommand.add_argument("--ro-mount", action="append", default=[], dest="ro_mounts", metavar="SRC[:DST]", help="Mount read-only reference directory")
    init_subcommand.add_argument("--rw-mount", action="append", default=[], dest="rw_mounts", metavar="SRC[:DST]", help="Mount writable reference directory")
    init_subcommand.add_argument("--start", action="store_true", help="Also start the session after initializing")

    start_subcommand = subcommand.add_parser("start", help="Launch a agentbox session (optionally override the command)")
    subparser_with_name(start_subcommand).add_argument("exec_cmd", nargs="*", metavar="CMD", help="Command to run instead of AGENT_HARNESS (use -- to separate)")

    subparser_with_name(subcommand.add_parser("stop", help="Stop a agentbox session"))
    subparser_with_name(subcommand.add_parser("logs", help="Tail the proxy access log"))
    subparser_with_name(subcommand.add_parser("web", help="Print the mitmweb traffic-monitor URL"))
    subparser_with_name(subcommand.add_parser("remove", help="Stop and delete a session (containers, volumes, git remote, output repo)"))
    allow_subcommand = subparser_with_name(subcommand.add_parser("allow", help="Add a host to the egress allowlist"))
    allow_subcommand.add_argument("host")
    deny_subcommand = subparser_with_name(subcommand.add_parser("deny", help="Remove a host from the egress allowlist"))
    deny_subcommand.add_argument("host")
    subparser_with_name(subcommand.add_parser("proxy-reload", help="Reload the proxy config without restarting"))
    subparser_with_name(subcommand.add_parser("proxy-restart", help="Restart the proxy container"))
    subcommand.add_parser("remote-cleanup", help="Remove agentbox-* git remotes with no matching session")

    mount_subcommand = subparser_with_name(subcommand.add_parser("mount", help="Manage read-only reference mounts for a session"))

    mount_subparser = mount_subcommand.add_subparsers(dest="subcmd")
    subparser_with_name(mount_subparser.add_parser("list"))

    mount_add = subparser_with_name(mount_subparser.add_parser("add"))
    mount_add.add_argument("spec", metavar="SRC[:DST]")
    mount_add.add_argument("-w", "--writable", action="store_true", help="Mount read-write instead of read-only")

    mount_remove = subparser_with_name(mount_subparser.add_parser("remove"))
    mount_remove.add_argument("dst", metavar="DST")

    preset_subcommand = subcommand.add_parser("preset", help="Manage presets")
    preset_subparser = preset_subcommand.add_subparsers(dest="subcmd")
    preset_subparser.add_parser("list")
    preset_edit = preset_subparser.add_parser("edit", help="Edit proxy or agent config of a preset")
    preset_edit.add_argument("file", choices=["proxy", "agent"])
    preset_edit.add_argument("name", nargs="?", default=AGENTBOX_PRESET)
    preset_copy = preset_subparser.add_parser("copy")
    preset_copy.add_argument("src")
    preset_copy.add_argument("dst")

    args = parser.parse_args()
    if not args.cmd:
        parser.print_help()
        return

    COMMANDS = {
        "build": cmd_build,
        "update": cmd_update,
        "init": cmd_init,
        "start": cmd_start,
        "stop": cmd_stop,
        "logs": cmd_logs,
        "web": cmd_web,
        "allow": cmd_allow,
        "deny": cmd_deny,
        "proxy-reload": cmd_proxy_reload,
        "proxy-restart": cmd_proxy_restart,
        "mount": cmd_mount,
        "status": cmd_status,
        "list": cmd_list,
        "ls": cmd_list,
        "remove": cmd_remove,
        "remote-cleanup": cmd_remote_cleanup,
        "preset": cmd_preset,
    }

    try:
        COMMANDS[args.cmd](args)
    except subprocess.CalledProcessError as exc:
        sys.exit(exc.returncode)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
