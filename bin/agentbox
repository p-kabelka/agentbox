#!/usr/bin/env python3
"""agentbox — isolated agent workspace manager"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import NoReturn

import yaml

AGENTBOX_HOME   = Path(os.environ.get("AGENTBOX_HOME", Path.home() / ".local" / "share" / "agentbox"))
AGENTBOX_PRESET = os.environ.get("AGENTBOX_PRESET", "default")


# ── Helpers ───────────────────────────────────────────────────────────────────

def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def project_name(path: Path) -> str:
    name = re.sub(r"[^a-z0-9]+", "-", path.resolve().name.lower()).strip("-")
    return name or "agentbox"


def free_port() -> int:
    with socket.socket() as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def find_agentbox_dir() -> Path | None:
    d = Path.cwd()
    while d != d.parent:
        if (d / ".agentbox" / "sessions").is_dir():
            return d
        d = d.parent
    return None


def require_agentbox() -> Path:
    p = find_agentbox_dir()
    if p is None:
        die("no .agentbox/ found in this directory or any parent.\n"
            "       Run 'agentbox run --name <name>' to create one.")
    return p  # type: ignore[return-value]


def get_sessions(project_dir: Path) -> list[str]:
    sessions_dir = project_dir / ".agentbox" / "sessions"
    return sorted(d.name for d in sessions_dir.iterdir() if d.is_dir()) if sessions_dir.is_dir() else []


def require_session(project_dir: Path, name: str | None) -> Path:
    """Return session_dir, auto-detecting if exactly one session exists."""
    sessions_dir = project_dir / ".agentbox" / "sessions"
    if name:
        d = sessions_dir / name
        if not d.is_dir():
            die(f"session '{name}' not found — run: agentbox list")
        return d
    sessions = get_sessions(project_dir)
    if len(sessions) == 1:
        return sessions_dir / sessions[0]
    elif not sessions:
        die("No sessions. Run: agentbox init --name <name>")
    else:
        die(f"Multiple sessions ({', '.join(sessions)}) — specify: --name <name>")
    raise AssertionError  # unreachable


def compose(session_dir: Path, *args: str, **kwargs) -> subprocess.CompletedProcess:
    name = session_dir.name
    project_dir = session_dir.parent.parent.parent
    agentbox_dir = project_dir / ".agentbox"
    env = {
        **os.environ,
        "AGENTBOX_HOME": str(AGENTBOX_HOME),
        "AGENTBOX_DIR":  str(agentbox_dir.resolve()),
    }
    cmd = [
        "podman", "compose",
        "--project-name", f"agentbox-{project_name(project_dir)}-{name}",
        "-f", str(AGENTBOX_HOME / "compose-base.yaml"),
        "-f", str((session_dir / "compose.override.yaml").resolve()),
        "--env-file", str((session_dir / ".env").resolve()),
        *args,
    ]
    return subprocess.run(cmd, env=env, **kwargs)


def wait_healthy(session_dir: Path) -> None:
    web_port = read_port(session_dir)
    print("==> Waiting for proxy", end="", flush=True)
    for _ in range(40):
        r = subprocess.run(["curl", "-so", "/dev/null", f"http://localhost:{web_port}/"], capture_output=True)
        if r.returncode == 0:
            print(" ready.")
            return
        print(".", end="", flush=True)
        time.sleep(2)
    print(" timed out!")
    compose(session_dir, "logs", "--tail=40", "proxy")
    sys.exit(1)


def read_env(session_dir: Path) -> dict[str, str]:
    env_file = session_dir / ".env"
    if not env_file.is_file():
        return {}
    return dict(line.split("=", 1) for line in env_file.read_text().splitlines() if "=" in line)


def read_port(session_dir: Path) -> int | None:
    val = read_env(session_dir).get("AGENTBOX_WEB_PORT")
    return int(val) if val else None


def load_yaml(path: Path) -> dict:
    with path.open() as f:
        return yaml.safe_load(f) or {}


def save_yaml(path: Path, cfg: dict) -> None:
    with path.open("w") as f:
        yaml.dump(cfg, f, default_flow_style=False, allow_unicode=True)


def read_mounts(agentbox_dir: Path) -> list[tuple[str, str]]:
    p = agentbox_dir / "mounts.yaml"
    if not p.is_file():
        return []
    return [(m["src"], m["dst"]) for m in (yaml.safe_load(p.read_text()) or [])]


def save_mounts(agentbox_dir: Path, mounts: list[tuple[str, str]]) -> None:
    data = [{"src": src, "dst": dst} for src, dst in mounts]
    (agentbox_dir / "mounts.yaml").write_text(
        yaml.dump(data, default_flow_style=False, allow_unicode=True)
    )


def write_override(session_dir: Path) -> None:
    name = session_dir.name
    project_dir = session_dir.parent.parent.parent
    agentbox_dir = project_dir / ".agentbox"
    web_port = read_port(session_dir) or 8081
    has_bundle = (session_dir / "source.bundle").is_file()
    has_output = (agentbox_dir / f"output-{name}.git").is_dir()

    dotfiles_dir = session_dir / "dotfiles"
    agent_volumes = ["proxy-ca:/proxy-ca:ro,Z"]
    if dotfiles_dir.is_dir():
        agent_volumes.append(f"{dotfiles_dir}:/agentbox-dotfiles:ro,Z")
    if has_bundle:
        agent_volumes.append(f"{session_dir}/source.bundle:/source/project.bundle:ro,Z")
    if has_output:
        agent_volumes.append(f"{agentbox_dir}/output-{name}.git:/output/repo.git:Z")
    if not has_bundle and not has_output:
        agent_volumes.append(f"{project_dir}:/workspace:Z")
    for src, dst in read_mounts(session_dir):
        agent_volumes.append(f"{src}:/context/{dst}:ro,Z")

    proxy_cfg = load_yaml(session_dir / "config" / "proxy.yaml")
    vertex_enabled = any(
        p.get("name") == "vertex" and p.get("enabled")
        for p in proxy_cfg.get("providers", [])
    )
    proxy_volumes = [f"{session_dir}/config/proxy.yaml:/config/proxy.yaml:ro,Z"]
    if vertex_enabled:
        gcloud = Path.home() / ".config" / "gcloud"
        if gcloud.is_dir():
            proxy_volumes.append(f"{gcloud}:/root/.config/gcloud:ro,Z")

    agent_cfg = load_yaml(session_dir / "config" / "agent.yaml") if (session_dir / "config" / "agent.yaml").is_file() else {}

    agent: dict = {"runtime": "krun", "volumes": agent_volumes}
    if env := agent_cfg.get("environment"):
        agent["environment"] = env

    proxy: dict = {
        "ports": [f"127.0.0.1:{web_port}:8081"],
        "volumes": proxy_volumes,
    }
    if proxy_env := proxy_cfg.get("environment"):
        proxy["environment"] = proxy_env

    override = {
        "services": {
            "proxy": proxy,
            "agent": agent,
        }
    }

    (session_dir / "compose.override.yaml").write_text(
        "# Generated by agentbox — re-run 'agentbox init' to regenerate.\n"
        + yaml.dump(override, default_flow_style=False, allow_unicode=True, sort_keys=False)
    )


# ── Commands ──────────────────────────────────────────────────────────────────

def _build_images(no_cache: bool = False) -> None:
    extra = ["--no-cache"] if no_cache else []

    (AGENTBOX_HOME / "secrets").mkdir(parents=True, exist_ok=True)

    # Stage host claude binary into agent build context
    claude_src = Path.home() / ".local" / "bin" / "claude"
    claude_staged = AGENTBOX_HOME / "agent" / "claude"
    if not claude_src.is_file():
        die(f"claude binary not found at {claude_src}")
    shutil.copy2(claude_src, claude_staged)

    try:
        for tag, ctx in [
            ("localhost/agentbox-proxy:latest", AGENTBOX_HOME / "proxy"),
            ("localhost/agentbox-agent:latest", AGENTBOX_HOME / "agent"),
        ]:
            subprocess.run(["podman", "build", *extra, "-t", tag, str(ctx)], check=True)
    finally:
        claude_staged.unlink(missing_ok=True)


def cmd_build(args) -> None:
    print("==> Building images...")
    _build_images()
    print("==> Done. Run 'agentbox update' after pulling a new version.")


def cmd_update(args) -> None:
    print("==> Rebuilding images without cache...")
    _build_images(no_cache=True)
    print("==> Done.")


def _launch(session_dir: Path) -> None:
    name = session_dir.name
    project_dir = session_dir.parent.parent.parent
    compose(session_dir, "up", "-d", "proxy", check=True)
    wait_healthy(session_dir)
    web_port = read_port(session_dir)
    if web_port:
        print(f"  Traffic monitor: http://localhost:{web_port} | agentbox logs | git fetch agentbox-{name}")
    result = compose(session_dir, "run", "--rm", "agent")
    # Auto-fetch when the session ends
    output_git = project_dir / ".agentbox" / f"output-{name}.git"
    if output_git.is_dir():
        print(f"\n==> Fetching agent output (agentbox-{name})...")
        r = subprocess.run(
            ["git", "-C", str(project_dir), "-c", "core.hooksPath=/dev/null",
             "fetch", f"agentbox-{name}"],
        )
        if r.returncode == 0:
            ls = subprocess.run(
                ["git", "-C", str(project_dir), "branch", "-r", "--list", f"agentbox-{name}/*"],
                capture_output=True, text=True,
            )
            branches = [b.strip() for b in ls.stdout.splitlines() if b.strip()]
            for b in branches:
                print(f"  {b}")
            if branches:
                print(f"  To apply: git merge {branches[0]}")
    sys.exit(result.returncode)


def cmd_init(args) -> None:
    project_dir = Path(args.dir).resolve() if args.dir else Path.cwd()
    agentbox_dir = project_dir / ".agentbox"
    name = args.name or time.strftime("%Y%m%d-%H%M%S")
    if not re.match(r"^[a-z0-9][a-z0-9._-]*$", name):
        die(f"invalid session name '{name}' — use lowercase letters, digits, hyphens, dots")
    session_dir = agentbox_dir / "sessions" / name

    print(f"==> Initializing agentbox '{name}': {project_dir}")
    agentbox_dir.mkdir(parents=True, exist_ok=True)
    session_dir.mkdir(parents=True, exist_ok=True)
    (session_dir / "config").mkdir(exist_ok=True)

    config_file = session_dir / "config" / "proxy.yaml"
    agent_config_file = session_dir / "config" / "agent.yaml"
    preset_dir = AGENTBOX_HOME / "presets" / args.preset
    if not (preset_dir / "proxy.yaml").is_file():
        die(f"preset '{args.preset}' not found at {preset_dir}")
    if not config_file.is_file():
        shutil.copy(preset_dir / "proxy.yaml", config_file)
        print(f"    Copied preset '{args.preset}' — edit .agentbox/sessions/{name}/config/proxy.yaml to enable providers.")
    if not agent_config_file.is_file() and (preset_dir / "agent.yaml").is_file():
        shutil.copy(preset_dir / "agent.yaml", agent_config_file)

    # Write dotfiles from agent config into session dotfiles directory
    dotfiles = load_yaml(agent_config_file).get("dotfiles", {}) if agent_config_file.is_file() else {}
    if dotfiles:
        dotfiles_dir = session_dir / "dotfiles"
        for rel_path, content in dotfiles.items():
            clean = rel_path.lstrip("~").lstrip("/")
            dest = dotfiles_dir / clean
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_text(content or "")

    git_available = False
    use_git = not args.no_git
    if use_git:
        in_repo = subprocess.run(
            ["git", "-C", str(project_dir), "rev-parse", "--git-dir"],
            capture_output=True,
        ).returncode == 0

        if in_repo:
            git_available = True
            branch = args.branch
            if not branch:
                branch = subprocess.run(
                    ["git", "-C", str(project_dir), "branch", "--show-current"],
                    capture_output=True, text=True,
                ).stdout.strip()
            if not branch:  # detached HEAD
                branch = subprocess.run(
                    ["git", "-C", str(project_dir), "rev-parse", "--short", "HEAD"],
                    capture_output=True, text=True, check=True,
                ).stdout.strip()
                print(f"    Detached HEAD — snapshotting commit {branch}")

            print(f"==> Creating source bundle (branch: {branch})...")
            subprocess.run(
                ["git", "-C", str(project_dir), "bundle", "create",
                 str(session_dir / "source.bundle"), "HEAD", branch],
                check=True,
            )

            output_git = agentbox_dir / f"output-{name}.git"
            subprocess.run(["git", "init", "--bare", str(output_git), "--quiet"], check=True)
            (output_git / "hooks").mkdir(exist_ok=True)
            (output_git / "hooks").chmod(0o555)

            remote = f"agentbox-{name}"
            has_remote = subprocess.run(
                ["git", "-C", str(project_dir), "remote", "get-url", remote],
                capture_output=True,
            ).returncode == 0
            if has_remote:
                subprocess.run(["git", "-C", str(project_dir), "remote", "set-url", remote, str(output_git.resolve())], check=True)
            else:
                subprocess.run(["git", "-C", str(project_dir), "remote", "add", remote, str(output_git.resolve())], check=True)
            print(f"    Git remote '{remote}' registered — 'git fetch {remote}' to review output mid-session.")
        else:
            print("    No git repo found; falling back to --no-git mode.")
            use_git = False

    web_port = read_port(session_dir) or free_port()
    (session_dir / ".env").write_text(
        f"AGENTBOX_WEB_PORT={web_port}\nAGENT_HARNESS={args.harness}\nAGENTBOX_NAME={name}\n"
    )

    if args.mounts:
        existing = read_mounts(session_dir)
        existing_dsts = {d for _, d in existing}
        for spec in args.mounts:
            src_str, _, dst = spec.partition(":")
            src = str(Path(src_str).resolve())
            dst = dst or Path(src_str).name
            if not Path(src).exists():
                die(f"mount source does not exist: {src}")
            if dst not in existing_dsts:
                existing.append((src, dst))
                existing_dsts.add(dst)
        save_mounts(session_dir, existing)

    write_override(session_dir)

    if git_available:
        gitignore = project_dir / ".gitignore"
        existing = gitignore.read_text() if gitignore.is_file() else ""
        if ".agentbox/" not in existing.splitlines():
            with gitignore.open("a") as f:
                f.write(".agentbox/\n")

    if args.start:
        _launch(session_dir)
    else:
        print(f"  Initialized. Run 'agentbox start --name {name}' to start.")


def cmd_start(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    write_override(session_dir)
    _launch(session_dir)


def cmd_stop(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    compose(session_dir, "down", check=True)


def cmd_shell(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    compose(session_dir, "up", "-d", "proxy", check=True)
    wait_healthy(session_dir)
    result = compose(session_dir, "run", "--rm", "agent", "/start.sh", "--shell")
    sys.exit(result.returncode)


def cmd_logs(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    result = compose(session_dir, "logs", "--follow", "--tail=100", "proxy")
    sys.exit(result.returncode)


def cmd_web(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    web_port = read_port(session_dir)
    if not web_port:
        die("AGENTBOX_WEB_PORT not found in session .env")
    print(f"http://localhost:{web_port}")


def _update_allowlist(host: str, add: bool, name: str | None) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, name)
    config_path = session_dir / "config" / "proxy.yaml"
    cfg = load_yaml(config_path)
    hosts: list[str] = cfg.setdefault("extra_allowed_hosts", [])
    session_name = session_dir.name
    if add:
        if host not in hosts:
            hosts.append(host)
            save_yaml(config_path, cfg)
            print(f"Added '{host}' to allowlist for session '{session_name}'.")
        else:
            print(f"'{host}' already in allowlist for session '{session_name}'.")
    else:
        if host in hosts:
            hosts.remove(host)
            cfg["extra_allowed_hosts"] = hosts
            save_yaml(config_path, cfg)
            print(f"Removed '{host}' from allowlist for session '{session_name}'.")
        else:
            print(f"'{host}' not in allowlist for session '{session_name}'.")
    compose(session_dir, "restart", "proxy", check=True)
    wait_healthy(session_dir)


def cmd_allow(args) -> None:
    _update_allowlist(args.host, add=True, name=args.name)


def cmd_deny(args) -> None:
    _update_allowlist(args.host, add=False, name=args.name)


def cmd_remove(args) -> None:
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)
    name = session_dir.name
    agentbox_dir = project_dir / ".agentbox"

    compose(session_dir, "down", "-v", check=True)

    remote = f"agentbox-{name}"
    subprocess.run(["git", "-C", str(project_dir), "remote", "remove", remote],
                   capture_output=True)  # best-effort; may not be a git repo

    shutil.rmtree(session_dir, ignore_errors=True)

    output_git = agentbox_dir / f"output-{name}.git"
    shutil.rmtree(output_git, ignore_errors=True)

    print(f"Removed session '{name}'.")


def cmd_mount(args) -> None:
    sub = args.subcmd or "list"
    project_dir = require_agentbox()
    session_dir = require_session(project_dir, args.name)

    if sub == "list":
        mounts = read_mounts(session_dir)
        if not mounts:
            print("No extra reference mounts. Add one: agentbox mount add /path/to/project[:name]")
        else:
            for src, dst in mounts:
                tag = "  [MISSING]" if not Path(src).exists() else ""
                print(f"  {src}  →  /context/{dst}{tag}")

    elif sub == "add":
        src_str, _, dst = args.spec.partition(":")
        src = str(Path(src_str).resolve())
        dst = dst or Path(src_str).name
        if not Path(src).exists():
            die(f"source path does not exist: {src}")
        mounts = read_mounts(session_dir)
        if any(d == dst for _, d in mounts):
            die(f"/context/{dst} already mounted. Remove first: agentbox mount remove {dst}")
        mounts.append((src, dst))
        save_mounts(session_dir, mounts)
        write_override(session_dir)
        print(f"Added {src} → /context/{dst}. Start the session to apply.")

    elif sub == "remove":
        mounts = read_mounts(session_dir)
        filtered = [(s, d) for s, d in mounts if d != args.dst]
        if len(filtered) == len(mounts):
            die(f"no mount '{args.dst}' found. List: agentbox mount list")
        save_mounts(session_dir, filtered)
        write_override(session_dir)
        print(f"Removed /context/{args.dst}. Start the session to apply.")


def cmd_list(args) -> None:
    project_dir = require_agentbox()
    sessions = get_sessions(project_dir)
    if not sessions:
        print("No sessions. Run: agentbox init --name <name>")
        return
    running = subprocess.run(
        ["podman", "ps", "--filter", "label=com.docker.compose.project", "--format", "{{.Names}}"],
        capture_output=True, text=True,
    ).stdout.lower()
    pname_prefix = f"agentbox-{project_name(project_dir)}"
    for s in sessions:
        env = read_env(project_dir / ".agentbox" / "sessions" / s)
        port = env.get("AGENTBOX_WEB_PORT", "")
        active = f"{pname_prefix}-{s}_" in running
        status = "running" if active else "stopped"
        port_info = f"  http://localhost:{port}" if port and active else ""
        print(f"  {s}  [{status}]{port_info}")


def cmd_status(args) -> None:
    result = subprocess.run(
        ["podman", "ps",
         "--filter", "label=com.docker.compose.project",
         "--format", "table {{.Names}}\t{{.Status}}\t{{.Ports}}"],
        capture_output=True, text=True,
    )
    lines = [ln for ln in result.stdout.splitlines() if "agentbox" in ln.lower()]
    print("\n".join(lines) if lines else "(no running containers)")


def cmd_preset(args) -> None:
    sub = args.subcmd or "list"

    if sub == "list":
        for p in sorted((AGENTBOX_HOME / "presets").iterdir()):
            if p.is_dir():
                print(p.name)

    elif sub == "edit":
        filename = f"{args.file}.yaml"
        target = AGENTBOX_HOME / "presets" / args.name / filename
        if not target.is_file():
            die(f"preset '{args.name}' {filename} not found at {target}")
        subprocess.run([os.environ.get("EDITOR", "vi"), str(target)], check=True)
        print(f"Preset saved ({filename}).")

    elif sub == "copy":
        src_dir = AGENTBOX_HOME / "presets" / args.src
        if not (src_dir / "proxy.yaml").is_file():
            die(f"source preset '{args.src}' not found")
        dst_dir = AGENTBOX_HOME / "presets" / args.dst
        dst_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy(src_dir / "proxy.yaml", dst_dir / "proxy.yaml")
        if (src_dir / "agent.yaml").is_file():
            shutil.copy(src_dir / "agent.yaml", dst_dir / "agent.yaml")
        print(f"Created preset '{args.dst}' from '{args.src}'. Edit: agentbox preset edit <proxy|agent>{args.dst}")


# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMANDS = {
    "build": cmd_build, "update": cmd_update, "init":   cmd_init,
    "start": cmd_start, "stop":   cmd_stop,   "shell":  cmd_shell,
    "logs":  cmd_logs,  "web":    cmd_web,     "allow":  cmd_allow,
    "deny":  cmd_deny,  "mount":  cmd_mount,   "status": cmd_status,
    "list":  cmd_list,  "ls":     cmd_list,    "remove": cmd_remove,
    "preset": cmd_preset,
}


def _add_name(p: argparse.ArgumentParser) -> None:
    p.add_argument("--name", "-n", metavar="NAME",
                   help="Session name (auto-detected if only one session exists)")


def main() -> None:
    p = argparse.ArgumentParser(prog="agentbox", description="Isolated agent workspace manager.")
    sub = p.add_subparsers(dest="cmd")

    sub.add_parser("build",  help="Build proxy + agent images")
    sub.add_parser("update", help="Rebuild images without cache")
    sub.add_parser("list",   help="List sessions for the current project")
    sub.add_parser("ls",     help="Alias for list")
    sub.add_parser("status", help="List running agentbox containers")

    r = sub.add_parser("init", help="Initialize a new agentbox session (use --start to also launch)")
    r.add_argument("dir", nargs="?")
    r.add_argument("--name", "-n", metavar="NAME", help="Session name (default: timestamp)")
    r.add_argument("--preset",  default=AGENTBOX_PRESET)
    r.add_argument("--branch",  default="")
    r.add_argument("--harness", default=os.environ.get("AGENT_HARNESS", "claude"))
    r.add_argument("--no-git",  action="store_true")
    r.add_argument("--mount",   action="append", default=[], dest="mounts", metavar="SRC[:DST]")
    r.add_argument("--start",   action="store_true", help="Also start the session after initializing")

    for cmd_name, hlp in [
        ("start",  "Resume a agentbox session"),
        ("stop",   "Stop a agentbox session"),
        ("shell",  "Open a shell in the agent container"),
        ("logs",   "Tail the proxy access log"),
        ("web",    "Print the mitmweb traffic-monitor URL"),
        ("remove", "Stop and delete a session (containers, volumes, git remote, output repo)"),
    ]:
        _add_name(sub.add_parser(cmd_name, help=hlp))

    for cmd_name, hlp in [
        ("allow", "Add a host to the egress allowlist"),
        ("deny",  "Remove a host from the egress allowlist"),
    ]:
        c = sub.add_parser(cmd_name, help=hlp)
        c.add_argument("host")
        _add_name(c)

    mt    = sub.add_parser("mount", help="Manage read-only reference mounts for a session")
    _add_name(mt)
    mtsub = mt.add_subparsers(dest="subcmd")
    ml = mtsub.add_parser("list");   _add_name(ml)
    ma = mtsub.add_parser("add");    ma.add_argument("spec", metavar="SRC[:DST]"); _add_name(ma)
    mr = mtsub.add_parser("remove"); mr.add_argument("dst",  metavar="DST");       _add_name(mr)

    ps    = sub.add_parser("preset", help="Manage presets")
    pssub = ps.add_subparsers(dest="subcmd")
    pssub.add_parser("list")
    pe = pssub.add_parser("edit", help="Edit proxy or agent config of a preset")
    pe.add_argument("file", choices=["proxy", "agent"])
    pe.add_argument("name", nargs="?", default=AGENTBOX_PRESET)
    pc = pssub.add_parser("copy"); pc.add_argument("src"); pc.add_argument("dst")

    args = p.parse_args()
    if not args.cmd:
        p.print_help()
        return

    try:
        COMMANDS[args.cmd](args)
    except subprocess.CalledProcessError as exc:
        sys.exit(exc.returncode)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
