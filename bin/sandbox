#!/usr/bin/env python3
"""sandbox — isolated agent workspace manager"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import NoReturn

import yaml

SANDBOX_HOME   = Path(os.environ.get("AGENT_SANDBOX_HOME", Path.home() / ".agent-sandbox"))
SANDBOX_PRESET = os.environ.get("AGENT_SANDBOX_PRESET", "default")


# ── Helpers ───────────────────────────────────────────────────────────────────

def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def project_name(path: Path) -> str:
    name = re.sub(r"[^a-z0-9]+", "-", path.resolve().name.lower()).strip("-")
    return name or "sandbox"


def free_port() -> int:
    with socket.socket() as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def find_sandbox_dir() -> Path | None:
    d = Path.cwd()
    while d != d.parent:
        if (d / ".sandbox" / "compose.override.yaml").is_file():
            return d
        d = d.parent
    return None


def require_sandbox() -> Path:
    p = find_sandbox_dir()
    if p is None:
        die("no .sandbox/ found in this directory or any parent.\n"
            "       Run 'sandbox run' to create one.")
    return p  # type: ignore[return-value]


def compose(project_dir: Path, *args: str, **kwargs) -> subprocess.CompletedProcess:
    sandbox_dir = project_dir / ".sandbox"
    env = {
        **os.environ,
        "SANDBOX_HOME": str(SANDBOX_HOME),
        "SANDBOX_DIR":  str(sandbox_dir.resolve()),
    }
    cmd = [
        "podman", "compose",
        "--project-name", f"sandbox-{project_name(project_dir)}",
        "-f", str(SANDBOX_HOME / "compose-base.yaml"),
        "-f", str((sandbox_dir / "compose.override.yaml").resolve()),
        "--env-file", str((sandbox_dir / ".env").resolve()),
        *args,
    ]
    return subprocess.run(cmd, env=env, **kwargs)


def wait_healthy(project_dir: Path) -> None:
    web_port = read_port(project_dir / ".sandbox")
    print("==> Waiting for proxy", end="", flush=True)
    for _ in range(40):
        r = subprocess.run(["curl", "-so", "/dev/null", f"http://localhost:{web_port}/"], capture_output=True)
        if r.returncode == 0:
            print(" ready.")
            return
        print(".", end="", flush=True)
        time.sleep(2)
    print(" timed out!")
    compose(project_dir, "logs", "--tail=40", "proxy")
    sys.exit(1)


def read_port(sandbox_dir: Path) -> int | None:
    env_file = sandbox_dir / ".env"
    if env_file.is_file():
        for line in env_file.read_text().splitlines():
            if line.startswith("SANDBOX_WEB_PORT="):
                return int(line.split("=", 1)[1])
    return None


def load_yaml(path: Path) -> dict:
    with path.open() as f:
        return yaml.safe_load(f) or {}


def save_yaml(path: Path, cfg: dict) -> None:
    with path.open("w") as f:
        yaml.dump(cfg, f, default_flow_style=False, allow_unicode=True)


def read_mounts(sandbox_dir: Path) -> list[tuple[str, str]]:
    mounts_file = sandbox_dir / "mounts.yaml"
    if not mounts_file.is_file():
        return []
    data = yaml.safe_load(mounts_file.read_text()) or []
    return [(m["src"], m["dst"]) for m in data]


def save_mounts(sandbox_dir: Path, mounts: list[tuple[str, str]]) -> None:
    data = [{"src": src, "dst": dst} for src, dst in mounts]
    (sandbox_dir / "mounts.yaml").write_text(
        yaml.dump(data, default_flow_style=False, allow_unicode=True)
    )


def write_override(sandbox_dir: Path) -> None:
    project_dir = sandbox_dir.parent
    web_port    = read_port(sandbox_dir) or 8081
    has_bundle  = (sandbox_dir / "source.bundle").is_file()
    has_output  = (sandbox_dir / "output.git").is_dir()

    volume_lines = ["      - proxy-ca:/proxy-ca:ro,Z"]
    if has_bundle:
        volume_lines.append("      - ./source.bundle:/source/project.bundle:ro,Z")
    if has_output:
        volume_lines.append("      - ./output.git:/output/repo.git:Z")
    if not has_bundle and not has_output:
        volume_lines.append(f"      - {project_dir}:/workspace:Z")
    for src, dst in read_mounts(sandbox_dir):
        volume_lines.append(f"      - {src}:/context/{dst}:ro,Z")

    (sandbox_dir / "compose.override.yaml").write_text("\n".join([
        "# Generated by sandbox — re-run 'sandbox run' to regenerate.",
        "services:",
        "  proxy:",
        "    ports:",
        f'      - "127.0.0.1:{web_port}:8081"',
        "  agent:",
        "    # runtime: krun    # uncomment for VM-level KVM isolation",
        "    volumes:",
        *volume_lines,
        "",
    ]))


# ── Commands ──────────────────────────────────────────────────────────────────

def _build_images(no_cache: bool = False) -> None:
    extra = ["--no-cache"] if no_cache else []
    for tag, ctx in [
        ("localhost/agent-sandbox-proxy:latest", SANDBOX_HOME / "proxy"),
        ("localhost/agent-sandbox-agent:latest", SANDBOX_HOME / "agent"),
    ]:
        subprocess.run(["podman", "build", *extra, "-t", tag, str(ctx)], check=True)


def cmd_build(args) -> None:
    print("==> Building images...")
    _build_images()
    print("==> Done. Run 'sandbox update' after pulling a new version.")


def cmd_update(args) -> None:
    print("==> Rebuilding images without cache...")
    _build_images(no_cache=True)
    print("==> Done.")


def _launch(project_dir: Path) -> None:
    compose(project_dir, "up", "-d", "proxy", check=True)
    wait_healthy(project_dir)
    web_port = read_port(project_dir / ".sandbox")
    if web_port:
        print(f"  Traffic monitor: http://localhost:{web_port}  |  sandbox logs  |  sandbox fetch [ref]")
    result = compose(project_dir, "run", "--rm", "agent")
    sys.exit(result.returncode)


def cmd_run(args) -> None:
    project_dir = Path(args.dir).resolve() if args.dir else Path.cwd()
    sandbox_dir = project_dir / ".sandbox"

    print(f"==> Initializing sandbox: {project_dir}")
    sandbox_dir.mkdir(parents=True, exist_ok=True)
    (sandbox_dir / "config").mkdir(exist_ok=True)

    config_file = sandbox_dir / "config" / "proxy.yaml"
    if not config_file.is_file():
        preset_file = SANDBOX_HOME / "presets" / args.preset / "proxy.yaml"
        if not preset_file.is_file():
            die(f"preset '{args.preset}' not found at {preset_file}")
        shutil.copy(preset_file, config_file)
        print(f"    Copied preset '{args.preset}' → edit .sandbox/config/proxy.yaml to enable providers.")

    git_available = False
    use_git = not args.no_git
    if use_git:
        in_repo = subprocess.run(
            ["git", "-C", str(project_dir), "rev-parse", "--git-dir"],
            capture_output=True,
        ).returncode == 0

        if in_repo:
            git_available = True
            branch = args.branch
            if not branch:
                branch = subprocess.run(
                    ["git", "-C", str(project_dir), "branch", "--show-current"],
                    capture_output=True, text=True,
                ).stdout.strip()
            if not branch:  # detached HEAD
                branch = subprocess.run(
                    ["git", "-C", str(project_dir), "rev-parse", "--short", "HEAD"],
                    capture_output=True, text=True, check=True,
                ).stdout.strip()
                print(f"    Detached HEAD — snapshotting commit {branch}")

            print(f"==> Creating source bundle (branch: {branch})...")
            subprocess.run(
                ["git", "-C", str(project_dir), "bundle", "create",
                 str(sandbox_dir / "source.bundle"), "HEAD", branch],
                check=True,
            )
            output_git = sandbox_dir / "output.git"
            if not output_git.exists():
                subprocess.run(["git", "init", "--bare", str(output_git), "--quiet"], check=True)
                (output_git / "hooks").mkdir(exist_ok=True)
                (output_git / "hooks").chmod(0o555)  # block agent from planting host-side hooks
        else:
            print("    No git repo found; falling back to --no-git mode.")
            use_git = False

    web_port = read_port(sandbox_dir) or free_port()
    (sandbox_dir / ".env").write_text(
        f"SANDBOX_WEB_PORT={web_port}\nAGENT_HARNESS={args.harness}\n"
    )

    if args.mounts:
        existing = read_mounts(sandbox_dir)
        existing_dsts = {d for _, d in existing}
        for spec in args.mounts:
            src_str, _, dst = spec.partition(":")
            src = str(Path(src_str).resolve())
            dst = dst or Path(src_str).name
            if not Path(src).exists():
                die(f"mount source does not exist: {src}")
            if dst not in existing_dsts:
                existing.append((src, dst))
                existing_dsts.add(dst)
        save_mounts(sandbox_dir, existing)

    write_override(sandbox_dir)

    if git_available:
        gitignore = project_dir / ".gitignore"
        existing  = gitignore.read_text() if gitignore.is_file() else ""
        if ".sandbox/" not in existing.splitlines():
            with gitignore.open("a") as f:
                f.write(".sandbox/\n")

    _launch(project_dir)


def cmd_start(args) -> None:
    _launch(require_sandbox())


def cmd_stop(args) -> None:
    project_dir = require_sandbox()
    compose(project_dir, "down", check=True)


def cmd_shell(args) -> None:
    result = compose(require_sandbox(), "run", "--rm", "agent", "/start.sh", "--shell")
    sys.exit(result.returncode)


def cmd_logs(args) -> None:
    result = compose(require_sandbox(), "exec", "proxy", "tail", "-f", "/var/log/proxy/access.log")
    sys.exit(result.returncode)


def cmd_web(args) -> None:
    project_dir = require_sandbox()
    web_port = read_port(project_dir / ".sandbox")
    if not web_port:
        die("SANDBOX_WEB_PORT not found in .sandbox/.env")
    print(f"http://localhost:{web_port}")


def _update_allowlist(host: str, add: bool) -> None:
    project_dir = require_sandbox()
    config_path = project_dir / ".sandbox" / "config" / "proxy.yaml"
    cfg   = load_yaml(config_path)
    hosts: list[str] = cfg.setdefault("extra_allowed_hosts", [])
    if add:
        if host not in hosts:
            hosts.append(host)
            save_yaml(config_path, cfg)
            print(f"Added '{host}' to allowlist.")
        else:
            print(f"'{host}' already in allowlist.")
    else:
        if host in hosts:
            hosts.remove(host)
            cfg["extra_allowed_hosts"] = hosts
            save_yaml(config_path, cfg)
            print(f"Removed '{host}' from allowlist.")
        else:
            print(f"'{host}' not in allowlist.")
    compose(project_dir, "restart", "proxy", check=True)
    wait_healthy(project_dir)


def cmd_allow(args) -> None:
    _update_allowlist(args.host, add=True)


def cmd_deny(args) -> None:
    _update_allowlist(args.host, add=False)


def cmd_fetch(args) -> None:
    project_dir = require_sandbox()
    output_git  = project_dir / ".sandbox" / "output.git"
    if not output_git.is_dir():
        die(f"{output_git} not found. Was this sandbox started without --no-git?")
    subprocess.run(
        ["git", "-c", "core.hooksPath=/dev/null",
         "fetch", str(output_git), f"{args.ref}:refs/sandbox/{args.ref}"],
        check=True,
    )
    print(f"Fetched to refs/sandbox/{args.ref} — review with 'git log refs/sandbox/{args.ref}' before merging.")


def cmd_mount(args) -> None:
    sub = args.subcmd or "list"
    project_dir = require_sandbox()
    sandbox_dir = project_dir / ".sandbox"

    if sub == "list":
        mounts = read_mounts(sandbox_dir)
        if not mounts:
            print("No extra reference mounts. Add one: sandbox mount add /path/to/project[:name]")
        else:
            for src, dst in mounts:
                tag = "  [MISSING]" if not Path(src).exists() else ""
                print(f"  {src}  →  /context/{dst}{tag}")

    elif sub == "add":
        src_str, _, dst = args.spec.partition(":")
        src = str(Path(src_str).resolve())
        dst = dst or Path(src_str).name
        if not Path(src).exists():
            die(f"source path does not exist: {src}")
        mounts = read_mounts(sandbox_dir)
        if any(d == dst for _, d in mounts):
            die(f"/context/{dst} already mounted. Remove first: sandbox mount remove {dst}")
        mounts.append((src, dst))
        save_mounts(sandbox_dir, mounts)
        write_override(sandbox_dir)
        print(f"Added {src} → /context/{dst}. Restart agent: sandbox start")

    elif sub == "remove":
        mounts = read_mounts(sandbox_dir)
        filtered = [(s, d) for s, d in mounts if d != args.dst]
        if len(filtered) == len(mounts):
            die(f"no mount '{args.dst}' found. List mounts: sandbox mount list")
        save_mounts(sandbox_dir, filtered)
        write_override(sandbox_dir)
        print(f"Removed /context/{args.dst}. Restart agent: sandbox start")


def cmd_status(args) -> None:
    result = subprocess.run(
        ["podman", "ps",
         "--filter", "label=com.docker.compose.project",
         "--format", "table {{.Names}}\t{{.Status}}\t{{.Ports}}"],
        capture_output=True, text=True,
    )
    lines = [ln for ln in result.stdout.splitlines() if "sandbox" in ln.lower()]
    print("\n".join(lines) if lines else "(no running sandboxes)")


def cmd_preset(args) -> None:
    sub = args.subcmd or "list"

    if sub == "list":
        for p in sorted((SANDBOX_HOME / "presets").iterdir()):
            if p.is_dir():
                print(p.name)

    elif sub == "edit":
        target = SANDBOX_HOME / "presets" / args.name / "proxy.yaml"
        if not target.is_file():
            die(f"preset '{args.name}' not found at {target}")
        subprocess.run([os.environ.get("EDITOR", "vi"), str(target)], check=True)
        print("Preset saved. Existing sandboxes: edit .sandbox/config/proxy.yaml and restart proxy.")

    elif sub == "copy":
        src_file = SANDBOX_HOME / "presets" / args.src / "proxy.yaml"
        if not src_file.is_file():
            die(f"source preset '{args.src}' not found")
        dst_dir = SANDBOX_HOME / "presets" / args.dst
        dst_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy(src_file, dst_dir / "proxy.yaml")
        print(f"Created preset '{args.dst}' from '{args.src}'. Edit: sandbox preset edit {args.dst}")


# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMANDS = {
    "build": cmd_build, "update": cmd_update, "run": cmd_run,
    "start": cmd_start, "stop": cmd_stop,   "shell": cmd_shell,
    "logs":  cmd_logs,  "web":   cmd_web,    "allow": cmd_allow,
    "deny":  cmd_deny,  "fetch": cmd_fetch,  "mount": cmd_mount,
    "status": cmd_status, "preset": cmd_preset,
}


def main() -> None:
    p = argparse.ArgumentParser(prog="sandbox", description="Isolated agent workspace manager.")
    sub = p.add_subparsers(dest="cmd")

    sub.add_parser("build",  help="Build proxy + agent images")
    sub.add_parser("update", help="Rebuild images without cache")
    sub.add_parser("start",  help="Resume an existing sandbox")
    sub.add_parser("stop",   help="Stop all containers")
    sub.add_parser("shell",  help="Open a shell in the agent container")
    sub.add_parser("logs",   help="Tail the proxy access log")
    sub.add_parser("web",    help="Print the mitmweb traffic-monitor URL")
    sub.add_parser("status", help="List running sandboxes")

    r = sub.add_parser("run", help="Create and start a sandbox")
    r.add_argument("dir", nargs="?")
    r.add_argument("--preset",  default=SANDBOX_PRESET)
    r.add_argument("--branch",  default="")
    r.add_argument("--harness", default=os.environ.get("AGENT_HARNESS", "claude"))
    r.add_argument("--no-git",  action="store_true")
    r.add_argument("--mount",   action="append", default=[], dest="mounts", metavar="SRC[:DST]")

    for name, hlp in [("allow", "Add a host to the egress allowlist"),
                      ("deny",  "Remove a host from the egress allowlist")]:
        c = sub.add_parser(name, help=hlp)
        c.add_argument("host")

    fe = sub.add_parser("fetch", help="Safely fetch agent output (hooks disabled)")
    fe.add_argument("ref", nargs="?", default="agent-work")

    mt    = sub.add_parser("mount", help="Manage read-only reference mounts")
    mtsub = mt.add_subparsers(dest="subcmd")
    mtsub.add_parser("list")
    ma = mtsub.add_parser("add");    ma.add_argument("spec", metavar="SRC[:DST]")
    mr = mtsub.add_parser("remove"); mr.add_argument("dst",  metavar="DST")

    ps    = sub.add_parser("preset", help="Manage provider presets")
    pssub = ps.add_subparsers(dest="subcmd")
    pssub.add_parser("list")
    pe = pssub.add_parser("edit"); pe.add_argument("name", nargs="?", default=SANDBOX_PRESET)
    pc = pssub.add_parser("copy"); pc.add_argument("src"); pc.add_argument("dst")

    args = p.parse_args()
    if not args.cmd:
        p.print_help()
        return

    try:
        COMMANDS[args.cmd](args)
    except subprocess.CalledProcessError as exc:
        sys.exit(exc.returncode)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
