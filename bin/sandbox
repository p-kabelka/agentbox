#!/usr/bin/env python3
"""
sandbox — isolated agent workspace manager

Global install: ~/.agent-sandbox/bin/sandbox
Setup:          ./install.sh   (from the cloned repo)
First use:      sandbox preset edit && sandbox build
Start project:  cd your-project && sandbox run
"""

from __future__ import annotations

import os
import re
import shutil
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import NoReturn

import yaml

SANDBOX_HOME   = Path(os.environ.get("AGENT_SANDBOX_HOME",  Path.home() / ".agent-sandbox"))
SANDBOX_PRESET = os.environ.get("AGENT_SANDBOX_PRESET", "default")

USAGE = """\
sandbox — isolated agent workspace manager

SETUP COMMANDS
  build                    Build proxy + agent images (run once; reused by all projects)
  update                   Rebuild images without cache (after updating the repo)
  preset list              List available presets
  preset edit [NAME]       Edit a preset in $EDITOR (default: $AGENT_SANDBOX_PRESET)
  preset copy SRC DST      Copy a preset

PROJECT COMMANDS
  run [DIR] [OPTIONS]      Create and start a sandbox  ← main entry point
  start                    Resume an existing sandbox (proxy background, agent foreground)
  stop                     Stop all containers for this project
  shell                    Open an interactive shell inside the agent container
  logs                     Tail the structured proxy access log
  web                      Print the mitmweb traffic-monitor URL
  allow <HOST>             Add a host to the egress allowlist; restart proxy
  deny  <HOST>             Remove a host from the egress allowlist; restart proxy
  fetch [REF]              Safely fetch agent output to refs/sandbox/REF (hooks disabled)
  mount list               List extra reference mounts for this sandbox
  mount add  SRC[:DST]     Add a read-only reference mount at /context/DST
  mount remove DST         Remove a reference mount by its /context/DST name
  status                   List running sandboxes on this machine

OPTIONS for 'run'
  --preset  NAME           Use named preset           (default: $AGENT_SANDBOX_PRESET)
  --branch  BRANCH         Git branch to snapshot     (default: current branch)
  --harness HARNESS        Agent harness binary        (default: claude)
  --no-git                 Skip git isolation; mount working directory directly
  --mount   SRC[:DST]      Add a read-only reference mount at /context/DST (repeatable)
                           DST defaults to the source directory's basename

ENVIRONMENT
  AGENT_SANDBOX_HOME       Override install location      (default: ~/.agent-sandbox)
  AGENT_SANDBOX_PRESET     Override default preset name   (default: default)
  AGENT_HARNESS            Override default harness binary (default: claude)
  ANTHROPIC_API_KEY        API keys — set in shell; never stored in project files
  OPENAI_API_KEY
  VERTEX_PROJECT_ID / VERTEX_REGION

EXAMPLES
  sandbox build
  sandbox preset edit
  export ANTHROPIC_API_KEY=sk-ant-...

  cd ~/projects/my-app
  sandbox run                                    # snapshot current branch, start sandbox
  sandbox run --preset webdev --harness opencode
  sandbox allow pypi.org                         # open extra egress for this project
  sandbox logs                                   # watch proxy access log
  sandbox fetch agent-work                       # pull agent commits safely
  git merge refs/sandbox/agent-work
  sandbox stop
"""


# ── Helpers ───────────────────────────────────────────────────────────────────

def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def project_name(path: Path) -> str:
    """Produce a compose-safe project name from a directory path."""
    name = re.sub(r"[^a-z0-9]+", "-", path.resolve().name.lower()).strip("-")
    return name or "sandbox"


def free_port() -> int:
    """Find a free TCP port on localhost."""
    with socket.socket() as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def find_sandbox_dir() -> Path | None:
    """Walk up the directory tree to find the nearest project with .sandbox/."""
    d = Path.cwd()
    while d != d.parent:
        if (d / ".sandbox" / "compose.override.yaml").is_file():
            return d
        d = d.parent
    return None


def require_sandbox() -> Path:
    """Return the project directory containing .sandbox/, or exit."""
    p = find_sandbox_dir()
    if p is None:
        die(
            "no .sandbox/ found in the current directory or any parent.\n"
            "       Run 'sandbox run' to create one."
        )
    return p  # type: ignore[return-value]  # die() is NoReturn; mypy doesn't track it


def compose(project_dir: Path, *args: str, **kwargs) -> subprocess.CompletedProcess:
    """Run podman compose with the base + project override files."""
    sandbox_dir = project_dir / ".sandbox"
    env = {
        **os.environ,
        "SANDBOX_HOME": str(SANDBOX_HOME),
        "SANDBOX_DIR":  str(sandbox_dir.resolve()),
    }
    cmd = [
        "podman", "compose",
        "--project-name", f"sandbox-{project_name(project_dir)}",
        "-f", str(SANDBOX_HOME / "compose-base.yaml"),
        "-f", str((sandbox_dir / "compose.override.yaml").resolve()),
        "--env-file", str((sandbox_dir / ".env").resolve()),
        *args,
    ]
    return subprocess.run(cmd, env=env, **kwargs)


def wait_healthy(project_dir: Path) -> None:
    """Block until the proxy's mitmweb UI responds (signals CA cert is ready too)."""
    print("==> Waiting for proxy", end="", flush=True)
    for _ in range(40):
        r = compose(
            project_dir, "exec", "proxy", "curl", "-sf", "http://localhost:8081/",
            capture_output=True,
        )
        if r.returncode == 0:
            print(" ready.")
            return
        print(".", end="", flush=True)
        time.sleep(2)
    print(" timed out!")
    compose(project_dir, "logs", "--tail=40", "proxy")
    sys.exit(1)


def read_port(sandbox_dir: Path) -> int | None:
    """Read SANDBOX_WEB_PORT from .sandbox/.env, or None if not set."""
    env_file = sandbox_dir / ".env"
    if env_file.is_file():
        for line in env_file.read_text().splitlines():
            if line.startswith("SANDBOX_WEB_PORT="):
                return int(line.split("=", 1)[1])
    return None


def load_yaml(path: Path) -> dict:
    with path.open() as f:
        return yaml.safe_load(f) or {}


def save_yaml(path: Path, cfg: dict) -> None:
    with path.open("w") as f:
        yaml.dump(cfg, f, default_flow_style=False, allow_unicode=True)


def read_mounts(sandbox_dir: Path) -> list[tuple[str, str]]:
    """Read extra reference mounts from .sandbox/mounts.yaml → [(src, dst), ...]."""
    mounts_file = sandbox_dir / "mounts.yaml"
    if not mounts_file.is_file():
        return []
    data = yaml.safe_load(mounts_file.read_text()) or []
    return [(m["src"], m["dst"]) for m in data]


def save_mounts(sandbox_dir: Path, mounts: list[tuple[str, str]]) -> None:
    """Persist extra reference mounts to .sandbox/mounts.yaml."""
    data = [{"src": src, "dst": dst} for src, dst in mounts]
    (sandbox_dir / "mounts.yaml").write_text(
        yaml.dump(data, default_flow_style=False, allow_unicode=True)
    )


def write_override(sandbox_dir: Path) -> None:
    """(Re)generate compose.override.yaml from current sandbox state.

    Called by both cmd_run (initial creation) and cmd_mount (live update).
    Source of truth for structural state: .env (port), presence of source.bundle /
    output.git (git mode), and mounts.yaml (extra reference mounts).
    """
    project_dir = sandbox_dir.parent
    web_port    = read_port(sandbox_dir) or 8081
    has_bundle  = (sandbox_dir / "source.bundle").is_file()
    has_output  = (sandbox_dir / "output.git").is_dir()

    volume_lines = ["      - proxy-ca:/proxy-ca:ro,Z"]
    if has_bundle:
        volume_lines.append("      - ./source.bundle:/source/project.bundle:ro,Z")
    if has_output:
        volume_lines.append("      - ./output.git:/output/repo.git:Z")
    if not has_bundle and not has_output:
        # --no-git mode: direct directory mount
        volume_lines.append(f"      - {project_dir}:/workspace:Z")
    for src, dst in read_mounts(sandbox_dir):
        volume_lines.append(f"      - {src}:/context/{dst}:ro,Z")

    override = "\n".join([
        "# Generated by sandbox — edit freely. Re-run 'sandbox run' to regenerate.",
        "# config/proxy.yaml and mounts.yaml are never overwritten by regeneration.",
        "",
        "services:",
        "",
        "  proxy:",
        "    ports:",
        f'      - "127.0.0.1:{web_port}:8081"',
        "",
        "  agent:",
        "    # runtime: krun    # uncomment for VM-level KVM isolation (requires krun)",
        "    volumes:",
        *volume_lines,
        "",
    ])
    (sandbox_dir / "compose.override.yaml").write_text(override)


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_build(_: list[str]) -> None:
    print("==> Building proxy image  (localhost/agent-sandbox-proxy:latest)...")
    subprocess.run(
        ["podman", "build", "-t", "localhost/agent-sandbox-proxy:latest",
         str(SANDBOX_HOME / "proxy")],
        check=True,
    )
    print("==> Building agent image  (localhost/agent-sandbox-agent:latest)...")
    subprocess.run(
        ["podman", "build", "-t", "localhost/agent-sandbox-agent:latest",
         str(SANDBOX_HOME / "agent")],
        check=True,
    )
    print("==> Done. Images are shared by all sandboxes.")
    print("    Run 'sandbox update' after pulling a new version of agent-sandbox.")


def cmd_update(_: list[str]) -> None:
    print("==> Rebuilding images without cache...")
    for tag, ctx in [
        ("localhost/agent-sandbox-proxy:latest", SANDBOX_HOME / "proxy"),
        ("localhost/agent-sandbox-agent:latest", SANDBOX_HOME / "agent"),
    ]:
        subprocess.run(["podman", "build", "--no-cache", "-t", tag, str(ctx)], check=True)
    print("==> Done. Running sandboxes will use the new images on next restart.")


def cmd_run(argv: list[str]) -> None:
    # ── Argument parsing ──────────────────────────────────────────────────────
    project_dir_arg: str | None = None
    preset  = SANDBOX_PRESET
    branch  = ""
    harness = os.environ.get("AGENT_HARNESS", "claude")
    use_git = True
    mounts: list[str] = []

    i = 0
    while i < len(argv):
        a = argv[i]
        if   a in ("--preset",  ) and i + 1 < len(argv): preset  = argv[i + 1]; i += 2
        elif a in ("--branch",  ) and i + 1 < len(argv): branch  = argv[i + 1]; i += 2
        elif a in ("--harness", ) and i + 1 < len(argv): harness = argv[i + 1]; i += 2
        elif a in ("--mount",   ) and i + 1 < len(argv): mounts.append(argv[i + 1]); i += 2
        elif a == "--no-git": use_git = False; i += 1
        elif a.startswith("-"):  die(f"unknown option: {a}")
        else: project_dir_arg = a; i += 1

    project_dir = Path(project_dir_arg).resolve() if project_dir_arg else Path.cwd()
    sandbox_dir = project_dir / ".sandbox"
    pname       = project_name(project_dir)

    print(f"==> Initializing sandbox for: {project_dir}  (project: {pname})")

    sandbox_dir.mkdir(parents=True, exist_ok=True)
    (sandbox_dir / "config").mkdir(exist_ok=True)

    # ── Preset ────────────────────────────────────────────────────────────────
    config_file = sandbox_dir / "config" / "proxy.yaml"
    if not config_file.is_file():
        preset_file = SANDBOX_HOME / "presets" / preset / "proxy.yaml"
        if not preset_file.is_file():
            die(f"preset '{preset}' not found at {preset_file}")
        shutil.copy(preset_file, config_file)
        print(f"    Preset '{preset}' copied to .sandbox/config/proxy.yaml")
        print("    Edit it to enable providers and add extra_allowed_hosts.")
    else:
        print("    Using existing .sandbox/config/proxy.yaml")

    # ── Git isolation ─────────────────────────────────────────────────────────
    git_available = False
    if use_git:
        in_repo = subprocess.run(
            ["git", "-C", str(project_dir), "rev-parse", "--git-dir"],
            capture_output=True,
        ).returncode == 0

        if in_repo:
            git_available = True

            if not branch:
                r = subprocess.run(
                    ["git", "-C", str(project_dir), "branch", "--show-current"],
                    capture_output=True, text=True,
                )
                branch = r.stdout.strip()

            if not branch:  # detached HEAD
                r = subprocess.run(
                    ["git", "-C", str(project_dir), "rev-parse", "--short", "HEAD"],
                    capture_output=True, text=True, check=True,
                )
                branch = r.stdout.strip()
                print(f"    Detached HEAD; snapshotting commit: {branch}")

            print(f"==> Creating source bundle (branch: {branch})...")
            subprocess.run(
                ["git", "-C", str(project_dir), "bundle", "create",
                 str(sandbox_dir / "source.bundle"), "HEAD", branch],
                check=True,
            )

            output_git = sandbox_dir / "output.git"
            if not output_git.exists():
                print("==> Initializing output bare repo...")
                subprocess.run(
                    ["git", "init", "--bare", str(output_git), "--quiet"],
                    check=True,
                )
                # Make hooks/ read-only so the agent cannot plant host-side hooks
                (output_git / "hooks").chmod(0o555)
        else:
            print("    No git repo found; falling back to --no-git mode.")
            use_git = False

    # ── Port ──────────────────────────────────────────────────────────────────
    web_port = read_port(sandbox_dir) or free_port()

    # ── .sandbox/.env ─────────────────────────────────────────────────────────
    (sandbox_dir / ".env").write_text(
        f"SANDBOX_WEB_PORT={web_port}\n"
        f"AGENT_HARNESS={harness}\n"
    )

    # ── Persist --mount args to mounts.yaml, then write override ─────────────
    if mounts:
        existing     = read_mounts(sandbox_dir)
        existing_dsts = {d for _, d in existing}
        for spec in mounts:
            src_str, _, dst = spec.partition(":")
            src = str(Path(src_str).resolve())
            dst = dst or Path(src_str).name
            if not Path(src).exists():
                die(f"mount source does not exist: {src}")
            if dst not in existing_dsts:
                existing.append((src, dst))
                existing_dsts.add(dst)
        save_mounts(sandbox_dir, existing)

    write_override(sandbox_dir)

    # ── .gitignore ────────────────────────────────────────────────────────────
    if git_available:
        gitignore = project_dir / ".gitignore"
        existing  = gitignore.read_text() if gitignore.is_file() else ""
        if ".sandbox/" not in existing.splitlines():
            with gitignore.open("a") as f:
                f.write(".sandbox/\n")
            print("    Added .sandbox/ to .gitignore")

    # ── Launch ────────────────────────────────────────────────────────────────
    print("==> Starting proxy (background)...")
    compose(project_dir, "up", "-d", "proxy", check=True)

    wait_healthy(project_dir)

    print()
    print(f"  Traffic monitor : http://localhost:{web_port}")
    print("  Logs            : sandbox logs")
    print("  Open egress     : sandbox allow <host>")
    print("  Get output      : sandbox fetch [ref]   (after agent pushes)")
    print()

    print(f"==> Starting {harness} (interactive)...")
    result = compose(project_dir, "run", "--rm", "agent")
    sys.exit(result.returncode)


def cmd_start(_: list[str]) -> None:
    project_dir = require_sandbox()
    compose(project_dir, "up", "-d", "proxy", check=True)
    wait_healthy(project_dir)
    web_port = read_port(project_dir / ".sandbox")
    if web_port:
        print(f"  Traffic monitor : http://localhost:{web_port}")
    print()
    result = compose(project_dir, "run", "--rm", "agent")
    sys.exit(result.returncode)


def cmd_stop(_: list[str]) -> None:
    project_dir = require_sandbox()
    print(f"==> Stopping sandbox for: {project_dir}")
    compose(project_dir, "down", check=True)


def cmd_shell(_: list[str]) -> None:
    project_dir = require_sandbox()
    print("==> Opening shell in agent container (proxy active; all traffic monitored)...")
    result = compose(project_dir, "run", "--rm", "agent", "/start.sh", "--shell")
    sys.exit(result.returncode)


def cmd_logs(_: list[str]) -> None:
    project_dir = require_sandbox()
    print("==> Tailing proxy access log (Ctrl+C to stop)...")
    print("    Hint: pipe through 'jq .' for pretty JSON")
    print()
    result = compose(project_dir, "exec", "proxy", "tail", "-f", "/var/log/proxy/access.log")
    sys.exit(result.returncode)


def cmd_web(_: list[str]) -> None:
    project_dir = require_sandbox()
    web_port = read_port(project_dir / ".sandbox")
    if not web_port:
        die("SANDBOX_WEB_PORT not found in .sandbox/.env")
    print(f"http://localhost:{web_port}")


def cmd_allow(argv: list[str]) -> None:
    if not argv:
        die("Usage: sandbox allow <host>")
    project_dir = require_sandbox()
    host        = argv[0]
    config_path = project_dir / ".sandbox" / "config" / "proxy.yaml"

    cfg   = load_yaml(config_path)
    hosts: list[str] = cfg.setdefault("extra_allowed_hosts", [])

    if host not in hosts:
        hosts.append(host)
        save_yaml(config_path, cfg)
        print(f"Added '{host}' to extra_allowed_hosts")
    else:
        print(f"'{host}' is already in extra_allowed_hosts")

    print("==> Restarting proxy to apply allowlist change...")
    compose(project_dir, "restart", "proxy", check=True)
    wait_healthy(project_dir)


def cmd_deny(argv: list[str]) -> None:
    if not argv:
        die("Usage: sandbox deny <host>")
    project_dir = require_sandbox()
    host        = argv[0]
    config_path = project_dir / ".sandbox" / "config" / "proxy.yaml"

    cfg   = load_yaml(config_path)
    hosts: list[str] = cfg.get("extra_allowed_hosts", [])

    if host in hosts:
        hosts.remove(host)
        cfg["extra_allowed_hosts"] = hosts
        save_yaml(config_path, cfg)
        print(f"Removed '{host}' from extra_allowed_hosts")
    else:
        print(f"'{host}' was not in extra_allowed_hosts")

    print("==> Restarting proxy to apply allowlist change...")
    compose(project_dir, "restart", "proxy", check=True)
    wait_healthy(project_dir)


def cmd_fetch(argv: list[str]) -> None:
    project_dir = require_sandbox()
    ref         = argv[0] if argv else "agent-work"
    output_git  = project_dir / ".sandbox" / "output.git"

    if not output_git.is_dir():
        die(
            f"{output_git} not found.\n"
            "       Was this sandbox started with git isolation (no --no-git)?"
        )

    print(f"==> Fetching '{ref}' from sandbox output repo...")
    print("    (core.hooksPath=/dev/null — any hooks the agent wrote are ignored)")
    print()

    subprocess.run(
        ["git", "-c", "core.hooksPath=/dev/null",
         "fetch", str(output_git), f"{ref}:refs/sandbox/{ref}"],
        check=True,
    )

    print()
    print(f"  Fetched to : refs/sandbox/{ref}")
    print()
    print(f"  Review  : git log refs/sandbox/{ref}")
    print(f"  Diff    : git diff HEAD refs/sandbox/{ref}")
    print(f"  Apply   : git merge refs/sandbox/{ref}")
    print( "            git cherry-pick"
          f" $(git merge-base HEAD refs/sandbox/{ref})..refs/sandbox/{ref}")
    print()
    print("  NOTE: Review commits before merging. If the agent modified a tracked")
    print("        hooks/ directory (e.g. .husky/), inspect those files first.")


def cmd_mount(argv: list[str]) -> None:
    sub  = argv[0] if argv else "list"
    rest = argv[1:]

    project_dir = require_sandbox()
    sandbox_dir = project_dir / ".sandbox"

    if sub == "list":
        mounts = read_mounts(sandbox_dir)
        if not mounts:
            print("No extra reference mounts.")
            print("Add one: sandbox mount add /path/to/project[:name]")
        else:
            print("Extra reference mounts (read-only inside agent):")
            for src, dst in mounts:
                tag = "" if Path(src).exists() else "  [PATH MISSING]"
                print(f"  {src}  →  /context/{dst}{tag}")
            print()
            print("Mounted paths are visible to the agent at /context/<name>.")

    elif sub == "add":
        if not rest:
            die("Usage: sandbox mount add SRC[:DST]\n"
                "       DST defaults to the source directory's basename")
        spec    = rest[0]
        src_str, _, dst = spec.partition(":")
        src = str(Path(src_str).resolve())
        dst = dst or Path(src_str).name

        if not Path(src).exists():
            die(f"source path does not exist: {src}")

        mounts = read_mounts(sandbox_dir)
        if any(d == dst for _, d in mounts):
            die(
                f"/context/{dst} is already mounted.\n"
                f"       Remove it first: sandbox mount remove {dst}"
            )

        mounts.append((src, dst))
        save_mounts(sandbox_dir, mounts)
        write_override(sandbox_dir)

        print(f"Added:  {src}  →  /context/{dst}")
        print()
        print("The override file is updated. Restart the agent to mount it:")
        print("  sandbox start")

    elif sub == "remove":
        if not rest:
            die("Usage: sandbox mount remove DST")
        dst    = rest[0]
        mounts = read_mounts(sandbox_dir)
        before = len(mounts)
        mounts = [(s, d) for s, d in mounts if d != dst]
        if len(mounts) == before:
            die(
                f"no mount with destination '{dst}' found.\n"
                f"       List mounts: sandbox mount list"
            )
        save_mounts(sandbox_dir, mounts)
        write_override(sandbox_dir)

        print(f"Removed mount for /context/{dst}")
        print()
        print("Restart the agent to apply the change:")
        print("  sandbox start")

    else:
        die(f"unknown mount subcommand: '{sub}'  (list | add | remove)")


def cmd_status(_: list[str]) -> None:
    print("Running sandbox containers:")
    result = subprocess.run(
        ["podman", "ps",
         "--filter", "label=com.docker.compose.project",
         "--format", "table {{.Names}}\t{{.Status}}\t{{.Ports}}"],
        capture_output=True, text=True,
    )
    lines = [ln for ln in result.stdout.splitlines() if "sandbox" in ln.lower()]
    print("\n".join(lines) if lines else "  (none)")


def cmd_preset(argv: list[str]) -> None:
    sub  = argv[0] if argv else "list"
    rest = argv[1:]

    if sub == "list":
        presets_dir = SANDBOX_HOME / "presets"
        print(f"Available presets (in {presets_dir}):")
        for p in sorted(presets_dir.iterdir()):
            if p.is_dir():
                print(f"  {p.name}")

    elif sub == "edit":
        name   = rest[0] if rest else SANDBOX_PRESET
        target = SANDBOX_HOME / "presets" / name / "proxy.yaml"
        if not target.is_file():
            die(f"preset '{name}' not found at {target}")
        subprocess.run([os.environ.get("EDITOR", "vi"), str(target)], check=True)
        print("Preset saved. New projects will use this preset.")
        print("Existing sandboxes: edit .sandbox/config/proxy.yaml, then restart proxy.")

    elif sub == "copy":
        if len(rest) < 2:
            die("Usage: sandbox preset copy SRC DST")
        src, dst = rest[0], rest[1]
        src_file = SANDBOX_HOME / "presets" / src / "proxy.yaml"
        if not src_file.is_file():
            die(f"source preset '{src}' not found")
        dst_dir = SANDBOX_HOME / "presets" / dst
        dst_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy(src_file, dst_dir / "proxy.yaml")
        print(f"Created preset '{dst}' from '{src}'.")
        print(f"Edit it: sandbox preset edit {dst}")

    else:
        die(f"unknown preset subcommand: {sub}")


# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMANDS: dict[str, object] = {
    "build":   cmd_build,
    "update":  cmd_update,
    "run":     cmd_run,
    "start":   cmd_start,
    "stop":    cmd_stop,
    "shell":   cmd_shell,
    "logs":    cmd_logs,
    "web":     cmd_web,
    "allow":   cmd_allow,
    "deny":    cmd_deny,
    "fetch":   cmd_fetch,
    "mount":   cmd_mount,
    "status":  cmd_status,
    "preset":  cmd_preset,
}


def main() -> None:
    argv = sys.argv[1:]
    cmd  = argv[0] if argv else "help"
    rest = argv[1:]

    if cmd in ("-h", "--help", "help"):
        print(USAGE)
        return

    fn = COMMANDS.get(cmd)
    if fn is None:
        print(f"error: unknown command: {cmd}\n", file=sys.stderr)
        print(USAGE, file=sys.stderr)
        sys.exit(1)

    try:
        fn(rest)  # type: ignore[operator]
    except subprocess.CalledProcessError as exc:
        print(f"error: command failed (exit {exc.returncode})", file=sys.stderr)
        sys.exit(exc.returncode)
    except KeyboardInterrupt:
        print()
        sys.exit(130)


if __name__ == "__main__":
    main()
