FROM fedora:43

RUN dnf install -y \
        curl \
        git \
        ca-certificates \
        proxychains-ng \
        vim \
    && dnf clean all

COPY harnesses/ /usr/local/bin/
RUN rm -f /usr/local/bin/.placeholder

COPY start.sh /start.sh
RUN chmod +x /start.sh

RUN git config --global user.email "agent@agentbox" && \
    git config --global user.name "Agent"

WORKDIR /workspace
ENTRYPOINT ["/start.sh"]
