FROM fedora:44 AS verifier

ARG AGENTBOX_BUILD_OPENCODE_SKIP_VERIFICATION=0
RUN dnf install -y curl $([ "$AGENTBOX_BUILD_OPENCODE_SKIP_VERIFICATION" = "0" ] && echo gh) && dnf clean all

RUN --mount=type=secret,id=gh_token \
    curl -fsSLo /tmp/opencode.tar.gz \
        https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-x64.tar.gz && \
    if [ "$AGENTBOX_BUILD_OPENCODE_SKIP_VERIFICATION" = "0" ]; then \
        GH_TOKEN=$(cat /run/secrets/gh_token) \
        gh release verify-asset /tmp/opencode.tar.gz \
            --repo anomalyco/opencode; \
    else \
        echo "Warning: skipping opencode attestation verification"; \
    fi && \
    tar -xzf /tmp/opencode.tar.gz -C /tmp && \
    chmod +x /tmp/opencode

FROM localhost/agentbox-agent-base:latest
COPY --from=verifier /tmp/opencode /usr/local/bin/opencode
