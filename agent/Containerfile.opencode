FROM fedora:44 AS verifier

RUN dnf install -y curl jq && dnf clean all

RUN curl -fsSLo /usr/local/bin/cosign \
        https://github.com/sigstore/cosign/releases/latest/download/cosign-linux-amd64 && \
    chmod +x /usr/local/bin/cosign

RUN curl -fsSLo /tmp/opencode \
        https://github.com/sst/opencode/releases/latest/download/opencode-linux-x64 && \
    chmod +x /tmp/opencode

RUN DIGEST=$(sha256sum /tmp/opencode | cut -d' ' -f1) && \
    curl -fsSL \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/sst/opencode/attestations/sha256:${DIGEST}" \
        | jq '.attestations[0].bundle' > /tmp/bundle.json && \
    cosign verify-blob /tmp/opencode \
        --bundle /tmp/bundle.json \
        --certificate-identity-regexp 'https://github.com/sst/opencode/' \
        --certificate-oidc-issuer 'https://token.actions.githubusercontent.com'

FROM localhost/agentbox-agent-base:latest
COPY --from=verifier /tmp/opencode /usr/local/bin/opencode
