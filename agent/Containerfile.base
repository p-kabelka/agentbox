FROM fedora:44

RUN dnf install -y \
        curl \
        git \
        ca-certificates \
        proxychains-ng \
        vim \
        tmux \
        jq \
    && dnf clean all

COPY start.sh /start.sh
RUN chmod +x /start.sh

RUN git config --global user.email "agent@agentbox" && \
    git config --global user.name "Agent"

WORKDIR /workspace
ENTRYPOINT ["/start.sh"]
